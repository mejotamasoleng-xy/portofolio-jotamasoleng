    "github_url": "https://github.com/mejotamasoleng-xy/Kahawa-BUI",
    "demo_html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Kahawa BUI - Simulator</title>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css\">\n</head>\n<body class=\"bg-slate-50 font-sans p-4\">\n    <div class=\"max-w-md mx-auto bg-white rounded-2xl shadow-xl overflow-hidden border border-slate-100\">\n        <!-- Header -->\n        <div class=\"bg-amber-955 text-white p-4 flex justify-between items-center bg-amber-900\">\n            <div>\n                <h1 class=\"text-lg font-bold flex items-center gap-2\">\n                    <i class=\"bi bi-cup-hot-fill\"></i> Kahawa BUI\n                </h1>\n                <p class=\"text-xs text-amber-200\">Cafe Point of Sales Simulator</p>\n            </div>\n            <span class=\"bg-amber-800 text-amber-100 text-xs px-2 py-1 rounded font-mono\">Meja 04</span>\n        </div>\n\n        <!-- Main Order Interface -->\n        <div class=\"p-4\">\n            <div class=\"mb-4\">\n                <h2 class=\"text-sm font-semibold text-slate-700 mb-2\">Menu Terpopuler</h2>\n                <div class=\"grid grid-cols-2 gap-2\" id=\"menu-container\">\n                    <!-- Items injected here -->\n                </div>\n            </div>\n\n            <!-- Cart -->\n            <div class=\"border-t border-slate-100 pt-3 mb-4\">\n                <h2 class=\"text-sm font-semibold text-slate-700 mb-2 flex justify-between\">\n                    <span>Detail Pesanan</span>\n                    <span class=\"text-xs text-amber-800 font-normal\" id=\"cart-count\">0 item</span>\n                </h2>\n                <div class=\"space-y-2 max-h-36 overflow-y-auto mb-2\" id=\"cart-items\">\n                    <p class=\"text-xs text-slate-400 text-center py-4\">Belum ada menu yang dipilih.</p>\n                </div>\n                <div class=\"bg-slate-50 p-3 rounded-lg space-y-1 text-xs\">\n                    <div class=\"flex justify-between text-slate-600\">\n                        <span>Subtotal</span>\n                        <span id=\"subtotal-val\">Rp 0</span>\n                    </div>\n                    <div class=\"flex justify-between text-slate-600\">\n                        <span>Pajak (10%)</span>\n                        <span id=\"tax-val\">Rp 0</span>\n                    </div>\n                    <div class=\"flex justify-between font-bold text-slate-800 text-sm border-t border-slate-200/60 pt-1 mt-1\">\n                        <span>Total Bayar</span>\n                        <span id=\"total-val\">Rp 0</span>\n                    </div>\n                </div>\n            </div>\n\n            <!-- Actions -->\n            <div class=\"space-y-2\">\n                <div class=\"flex gap-2 \">\n                    <input type=\"number\" id=\"payment-input\" placeholder=\"Jumlah Bayar\" class=\"bg-white border border-slate-200 rounded-lg px-3 py-2 text-sm w-full font-mono outline-none focus:border-amber-800\">\n                    <button onclick=\"calculateReturn()\" class=\"bg-slate-800 text-white rounded-lg px-3 text-xs font-semibold hover:bg-slate-900 transition-colors\">Hitung Kembalian</button>\n                </div>\n                <div id=\"return-box\" class=\"hidden bg-amber-50 border border-amber-200 p-2.5 rounded-lg text-xs flex justify-between items-center text-amber-900 font-medium\">\n                    <span>Kembalian:</span>\n                    <span id=\"return-val\">Rp 0</span>\n                </div>\n                <button onclick=\"completeTransaction()\" class=\"w-full bg-amber-900 hover:bg-amber-800 text-white text-sm font-semibold py-3 rounded-xl shadow-lg shadow-amber-900/10 transition-all flex justify-center items-center gap-2\">\n                    <i class=\"bi bi-check-circle-fill\"></i> Simpan Transaksi\n                </button>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        const items = [\n            { id: 1, name: 'Espresso Latte', price: 22000, category: 'Hot' },\n            { id: 2, name: 'Iced Gula Aren', price: 24000, category: 'Ice' },\n            { id: 3, name: 'Matcha Brew', price: 26000, category: 'Ice' },\n            { id: 4, name: 'Croissant Butter', price: 18000, category: 'Snack' }\n        ];\n        let cart = [];\n\n        function renderMenu() {\n            const c = document.getElementById('menu-container');\n            c.innerHTML = items.map(item => `\n                <button onclick=\"addToCart(${item.id})\" class=\"bg-white border border-slate-200 p-3 rounded-xl text-left hover:border-amber-800 transition-all cursor-pointer block w-full focus:ring-2 focus:ring-amber-800/10\">\n                    <p class=\"text-xs font-semibold text-slate-800\">${item.name}</p>\n                    <div class=\"flex justify-between items-center mt-1\">\n                        <span class=\"text-[11px] bg-slate-100 text-slate-600 px-1.5 py-0.5 rounded\">${item.category}</span>\n                        <span class=\"text-xs font-bold text-amber-800\">Rp ${item.price.toLocaleString('id-ID')}</span>\n                    </div>\n                </button>\n            `).join('');\n        }\n\n        function addToCart(id) {\n            const item = items.find(i => i.id === id);\n            const existing = cart.find(c => c.id === id);\n            if (existing) {\n                existing.qty++;\n            } else {\n                cart.push({ ...item, qty: 1 });\n            }\n            updateCart();\n        }\n\n        function changeQty(id, delta) {\n            const idx = cart.findIndex(c => c.id === id);\n            if (idx > -1) {\n                cart[idx].qty += delta;\n                if (cart[idx].qty <= 0) {\n                    cart.splice(idx, 1);\n                }\n            }\n            updateCart();\n        }\n\n        function updateCart() {\n            const itemsContainer = document.getElementById('cart-items');\n            const countEl = document.getElementById('cart-count');\n            \n            if (cart.length === 0) {\n                itemsContainer.innerHTML = '<p class=\"text-xs text-slate-400 text-center py-4\">Belum ada menu yang dipilih.</p>';\n                countEl.textContent = '0 item';\n                document.getElementById('subtotal-val').textContent = 'Rp 0';\n                document.getElementById('tax-val').textContent = 'Rp 0';\n                document.getElementById('total-val').textContent = 'Rp 0';\n                return;\n            }\n\n            countEl.textContent = `${cart.reduce((a, b) => a + b.qty, 0)} item`;\n            itemsContainer.innerHTML = cart.map(c => `\n                <div class=\"flex justify-between items-center text-xs border-b border-slate-50 pb-2\">\n                    <div>\n                        <p class=\"font-medium text-slate-800\">${c.name}</p>\n                        <p class=\"text-[10px] text-slate-400\">Rp ${c.price.toLocaleString('id-ID')}</p>\n                    </div>\n                    <div class=\"flex items-center gap-1.5 bg-slate-100 rounded-lg p-0.5\">\n                        <button onclick=\"changeQty(${c.id}, -1)\" class=\"w-5 h-5 rounded bg-white font-bold flex items-center justify-center hover:bg-slate-200 cursor-pointer\">-</button>\n                        <span class=\"font-semibold w-4 text-center text-[10px]\">${c.qty}</span>\n                        <button onclick=\"changeQty(${c.id}, 1)\" class=\"w-5 h-5 rounded bg-white font-bold flex items-center justify-center hover:bg-slate-200 cursor-pointer\">+</button>\n                    </div>\n                </div>\n            `).join('');\n\n            const sub = cart.reduce((a, b) => a + (b.price * b.qty), 0);\n            const tax = Math.round(sub * 0.1);\n            const total = sub + tax;\n\n            document.getElementById('subtotal-val').textContent = `Rp ${sub.toLocaleString('id-ID')}`;\n            document.getElementById('tax-val').textContent = `Rp ${tax.toLocaleString('id-ID')}`;\n            document.getElementById('total-val').textContent = `Rp ${total.toLocaleString('id-ID')}`;\n        }\n\n        function calculateReturn() {\n            const totalValStr = document.getElementById('total-val').textContent.replace(/[^0-9]/g, '');\n            const total = parseInt(totalValStr) || 0;\n            const pay = parseInt(document.getElementById('payment-input').value) || 0;\n\n            if (total === 0) {\n                alert('Pesan menu terlebih dahulu!');\n                return;\n            }\n            if (pay < total) {\n                alert('Uang pembayaran kurang!');\n                return;\n            }\n\n            const ret = pay - total;\n            document.getElementById('return-val').textContent = `Rp ${ret.toLocaleString('id-ID')}`;\n            document.getElementById('return-box').classList.remove('hidden');\n        }\n\n        function completeTransaction() {\n            const totalValStr = document.getElementById('total-val').textContent.replace(/[^0-9]/g, '');\n            const total = parseInt(totalValStr) || 0;\n            if (total === 0) {\n                alert('Wah, keranjang belanja masih kosong nih!');\n                return;\n            }\n            alert('Pesanan Sukses Disimpan!\\nTotal Transaksi: Rp ' + total.toLocaleString('id-ID'));\n            cart = [];\n            updateCart();\n            document.getElementById('payment-input').value = '';\n            document.getElementById('return-box').classList.add('hidden');\n        }\n\n        renderMenu();\n    </script>\n</body>\n</html>",
    "status": "published",
    "tanggal_dibuat": "2026-05-31",
    "tanggal_update": "2026-05-31"
  },
  {
    "id": "proj_kedai_fizqo",
    "nama": "Kedai Fizqo - Tenant POS App",
    "kategori": "Sistem Informasi UMKM",
    "tagline": "Aplikasi Manajemen Tenant & Kasir Terintegrasi Foodcourt",
    "problem": "Pemilik tenant makanan berukuran mikro seringkali kesulitan mencatat pesanan harian, melacak menu mana yang paling laku, dan mencocokkan setoran harian dengan pengelola mall/foodcourt karena kurangnya otomatisasi pencatatan kasir.",
    "before_after": "Sebelumnya, omset dicatat di buku tulis yang gampang robek dan sering basah terkena minyak di dapur. Laporan pembagian hasil dengan foodcourt memakan waktu 2 jam per malam. Setelah otomasi, transaksi terdokumentasi rapi, model Dine-In vs Takeaway jelas, dan laporan omset selesai instan dalam 5 menit.",
    "fitur": [
      "Struktur Menu Dinamis Berdasarkan Stok Harian",
      "Kalkulasi Pajak & Biaya Layanan Kemitraan UMKM",
      "Dasbor Ringkasan Omset Harian Terintegrasi",
      "Pencatatan Pesanan Takeaway vs Dine-In",
      "Grafik Omset Mini Tanpa Dependency Eksternal"
    ],
    "impact_numbers": [
      { "label": "Reconciliation", "value": "5 Mins" },
      { "label": "Data Integrity", "value": "100%" },
      { "label": "Revenue Uplift", "value": "+12%" }
    ],
    "github_url": "https://github.com/mejotamasoleng-xy/kedai-fizqo",
    "demo_html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Kedai Fizqo - Simulator</title>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css\">\n</head>\n<body class=\"bg-neutral-900 text-neutral-100 font-sans p-4\">\n    <div class=\"max-w-md mx-auto bg-neutral-800 rounded-2xl shadow-2xl overflow-hidden border border-neutral-700\">\n        <!-- Header -->\n        <div class=\"bg-emerald-700 text-white p-4\">\n            <div class=\"flex justify-between items-center\">\n                <h1 class=\"text-lg font-black flex items-center gap-2 tracking-tight\">\n                    <i class=\"bi bi-shop\"></i> KEDAI FIZQO\n                </h1>\n                <span class=\"bg-emerald-600 text-xs px-2 py-0.5 rounded-full text-emerald-100\">Tenant Makan</span>\n            </div>\n            <p class=\"text-[10px] text-emerald-200 mt-1\">Demo Ringkas Sistem Informasi POS UMKM</p>\n        </div>\n\n        <div class=\"p-4 space-y-4\">\n            <!-- Menu selection -->\n            <div>\n                <h2 class=\"text-xs font-bold text-neutral-400 uppercase tracking-wider mb-2\">Daftar Menu Tersedia</h2>\n                <div class=\"grid grid-cols-2 gap-2\">\n                    <button onclick=\"addFood('Nasi Goreng Spesial', 18000)\" class=\"bg-neutral-700/60 p-2.5 rounded-xl border border-neutral-700 text-left hover:border-emerald-500 transition-all cursor-pointer w-full\">\n                        <span class=\"text-xs font-semibold block\">Nasi Goreng</span>\n                        <span class=\"text-xs text-emerald-400 font-bold\">Rp 18.000</span>\n                    </button>\n                    <button onclick=\"addFood('Mie Goreng Fizqo', 16000)\" class=\"bg-neutral-700/60 p-2.5 rounded-xl border border-neutral-700 text-left hover:border-emerald-500 transition-all cursor-pointer w-full\">\n                        <span class=\"text-xs font-semibold block\">Mie Goreng Fizqo</span>\n                        <span class=\"text-xs text-emerald-400 font-bold\">Rp 16.000</span>\n                    </button>\n                    <button onclick=\"addFood('Ayam Geprek Sambal', 20000)\" class=\"bg-neutral-700/60 p-2.5 rounded-xl border border-neutral-700 text-left hover:border-emerald-500 transition-all cursor-pointer w-full\">\n                        <span class=\"text-xs font-semibold block\">Ayam Geprek</span>\n                        <span class=\"text-xs text-emerald-400 font-bold\">Rp 20.000</span>\n                    </button>\n                    <button onclick=\"addFood('Teh Tarik Manis', 8000)\" class=\"bg-neutral-700/60 p-2.5 rounded-xl border border-neutral-700 text-left hover:border-emerald-500 transition-all cursor-pointer w-full\">\n                        <span class=\"text-xs font-semibold block\">Teh Tarik Manis</span>\n                        <span class=\"text-xs text-emerald-400 font-bold\">Rp 8.000</span>\n                    </button>\n                </div>\n            </div>\n\n            <!-- Transaction Log -->\n            <div class=\"bg-neutral-900/60 p-3 rounded-xl border border-neutral-700/50\">\n                <h3 class=\"text-xs font-bold text-neutral-400 uppercase tracking-wider mb-2 flex justify-between\">\n                    <span>Transaksi Berjalan</span>\n                    <span class=\"text-[11px] text-neutral-400 font-normal\" id=\"order-type\">Dine In</span>\n                </h3>\n                <div id=\"orders-list\" class=\"space-y-1.5 max-h-24 overflow-y-auto text-xs text-neutral-300 pb-2 mb-2\">\n                    <p class=\"text-neutral-500 text-center py-2\">Belum ada pesanan masuk.</p>\n                </div>\n                <div class=\"border-t border-neutral-700/60 pt-2 text-xs font-bold flex justify-between text-neutral-100\">\n                    <span>Total Akhir</span>\n                    <span id=\"grand-total\">Rp 0</span>\n                </div>\n            </div>\n\n            <!-- Submit -->\n            <div class=\"grid grid-cols-2 gap-2\">\n                <button onclick=\"toggleType()\" class=\"bg-neutral-700 hover:bg-neutral-600 font-semibold py-2.5 rounded-xl text-xs transition-colors cursor-pointer w-full\">Pilih Takeaway</button>\n                <button onclick=\"confirmOrder()\" class=\"bg-emerald-600 hover:bg-emerald-500 text-white font-bold py-2.5 rounded-xl text-xs shadow-lg shadow-emerald-900/30 transition-all cursor-pointer w-full\">Konfirmasi Bayar</button>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        let activeOrder = [];\n        let type = 'Dine In';\n\n        function toggleType() {\n            type = type === 'Dine In' ? 'Take Away' : 'Dine In';\n            document.getElementById('order-type').textContent = type;\n        }\n\n        function addFood(name, price) {\n            const existing = activeOrder.find(o => o.name === name);\n            if (existing) {\n                existing.qty++;\n            }\n            else {\n                activeOrder.push({ name, price, qty: 1 });\n            }\n            renderActive();\n        }\n\n        function renderActive() {\n            const container = document.getElementById('orders-list');\n            if (activeOrder.length === 0) {\n                container.innerHTML = '<p class=\"text-neutral-500 text-center py-2\">Belum ada pesanan masuk.</p>';\n                document.getElementById('grand-total').textContent = 'Rp 0';\n                return;\n            }\n            container.innerHTML = activeOrder.map((o, idx) => `\n                <div class=\"flex justify-between items-center\">\n                    <span>${o.name} (${o.qty}x)</span>\n                    <div class=\"flex items-center gap-2\">\n                        <span>Rp ${(o.price * o.qty).toLocaleString('id-ID')}</span>\n                        <button onclick=\"removeFood(${idx})\" class=\"text-red-400 hover:text-red-300 font-bold cursor-pointer\">×</button>\n                    </div>\n                </div>\n            `).join('');\n            \n            const sum = activeOrder.reduce((a, b) => a + (b.price * b.qty), 0);\n            document.getElementById('grand-total').textContent = `Rp ${sum.toLocaleString('id-ID')}`;\n        }\n\n        function removeFood(idx) {\n            activeOrder.splice(idx, 1);\n            renderActive();\n        }\n\n        function confirmOrder() {\n            if (activeOrder.length === 0) {\n                alert('Pesan makanan terlebih dahulu!');\n                return;\n            }\n            const total = activeOrder.reduce((a, b) => a + (b.price * b.qty), 0);\n            alert(`[Kedai Fizqo]\\nPemesan: ${type}\\nSukses diproses senilai Rp ${total.toLocaleString('id-ID')}`);\n            activeOrder = [];\n            renderActive();\n        }\n    </script>\n</body>\n</html>",
    "status": "published",
    "tanggal_dibuat": "2026-05-31",
    "tanggal_update": "2026-05-31"
  }
